# sys.toml -- single source of truth for all system identity, vocabulary, and configuration
# Generated by sys-scaffold from system-system--system
# Project: {{project_name}}

[versions]
manifest      = "0.1.0"
laws          = "1.0.0"
atom_registry = "0.1.0"

[schemas]
piece = "piece/v2"
law   = "law/v1"

[sop]
primary   = ""
amendment = ""

[layers]
names = ["distinction", "token", "relation", "rule", "flow", "feedback", "governance"]

[categories]
S = "Seed"
F = "Foundation"
P = "Primitives"
M = "Materia"
O = "Objects/Composition"
G = "Governance"
V = "Verse/Multiverse"

[domains]
names = ["Generative", "Foundation", "Primitives", "Materia", "Composition", "Governance", "Multiverse"]

[vocabulary.nature]
terms = ["FRAMEWORK", "CLAIM", "DEFINITION", "PROOF", "AXIOM", "MODEL", "DISTINCTION", "ALGORITHM", "SCHEMA", "QUESTION", "CONJECTURE", "PROTOCOL", "INSTRUCTION"]

[vocabulary.formalization]
terms = ["FORMAL", "SKETCHED", "INTUITIVE", "EXCISED", "VACUUM"]

[vocabulary.provenance]
terms = ["HYBRID", "LOCAL", "ALIEN"]

[vocabulary.integration]
phases = ["1A", "1B", "2A", "2B", "3A", "EXCISED", "VACUUM"]

[config]
max_depth      = 10
graph_fontname = "Helvetica"
graph_fontsize = 10
json_indent    = 2
registry_path  = "registry/data"
