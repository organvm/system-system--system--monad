#!/usr/bin/env python3
"""Extract temporal file-tree snapshots from git history.

Walks every commit on the current branch and outputs a JSON structure
mapping each commit to its complete file tree with container membership
and nesting depth.  Output goes to stdout.
"""
import json
import subprocess
import sys
from pathlib import Path

root = Path(__file__).resolve().parent.parent

def git(*args):
    res = subprocess.run(
        ["git", "-C", str(root)] + list(args),
        capture_output=True, text=True, check=True,
    )
    return res.stdout.strip()

def extract_tree(commit_hash):
    """Return (files, containers) for a single commit."""
    raw = git("ls-tree", "-r", "--name-only", commit_hash)
    if not raw:
        return [], []

    files = []
    container_counts = {}  # path -> file count

    for line in raw.splitlines():
        path = line.strip()
        if not path:
            continue
        # Skip dotfile directories (.claude/, .serena/, .gemini/, .git*)
        first = path.split("/")[0]
        if first.startswith("."):
            continue

        parts = path.split("/")
        depth = len(parts) - 1
        container = "/".join(parts[:-1]) if depth > 0 else "."

        files.append({"path": path, "depth": depth, "container": container})

        # Accumulate container counts (including all ancestor dirs)
        container_counts.setdefault(".", 0)
        for i in range(1, len(parts)):
            ancestor = "/".join(parts[:i])
            container_counts.setdefault(ancestor, 0)
        container_counts[container] = container_counts.get(container, 0) + 1

    containers = []
    for cpath, count in sorted(container_counts.items()):
        depth = 0 if cpath == "." else cpath.count("/") + 1
        containers.append({"path": cpath, "depth": depth, "file_count": count})

    return files, containers

def main():
    log_raw = git("log", "--reverse", "--format=%H|%s|%aI")
    if not log_raw:
        print("{}", file=sys.stderr)
        sys.exit(1)

    commits = []
    max_depth = 0
    max_files = 0

    for idx, line in enumerate(log_raw.splitlines()):
        parts = line.split("|", 2)
        if len(parts) < 3:
            continue
        commit_hash, message, timestamp = parts

        files, containers = extract_tree(commit_hash)
        if files:
            local_depth = max(f["depth"] for f in files)
            max_depth = max(max_depth, local_depth)
        max_files = max(max_files, len(files))

        commits.append({
            "hash": commit_hash[:7],
            "hash_full": commit_hash,
            "message": message,
            "timestamp": timestamp,
            "index": idx,
            "files": files,
            "containers": containers,
        })

    result = {
        "commits": commits,
        "meta": {
            "total_commits": len(commits),
            "max_depth": max_depth,
            "max_files": max_files,
        },
    }
    json.dump(result, sys.stdout, indent=2)

if __name__ == "__main__":
    main()
