#!/usr/bin/env python3
"""Extract ideal topology from manifest.toml, sys.toml, and atom-registry.yaml.

Produces a JSON structure mapping the conceptual system to its ideal
physical organization, identifying orphaned files and computing
file-to-piece mappings.  Output goes to stdout.
"""
import json
import sys
import tomllib
from pathlib import Path

import yaml

root = Path(__file__).resolve().parent.parent

def load_toml(name):
    with open(root / name, "rb") as f:
        return tomllib.load(f)

def load_yaml(name):
    with open(root / name) as f:
        return yaml.safe_load(f)

def load_laws(sys_cfg):
    """Extract law entries from LAWS.toml."""
    laws_data = load_toml("LAWS.toml")
    laws = []
    for key, val in laws_data.get("laws", {}).items():
        laws.append({
            "id": key,
            "statement": val.get("statement", ""),
            "source": val.get("source", ""),
        })
    return laws

def build_file_mapping(documents, atoms):
    """Map each documented file to its category, atoms, and optional law."""
    mapping = {}
    for doc_id, doc in documents.items():
        filepath = doc.get("file", "")
        if not filepath:
            continue
        atom_ids = doc.get("atoms", [])
        # Derive category from first atom ID: ATM-X-NNN -> X
        category = None
        if atom_ids:
            first = str(atom_ids[0])
            parts = first.split("-")
            if len(parts) >= 2:
                category = parts[1]

        atom_details = []
        for aid in atom_ids:
            aid_str = str(aid)
            if aid_str in atoms:
                atom_details.append({
                    "id": aid_str,
                    "nature": atoms[aid_str].get("nature", ""),
                    "domain": atoms[aid_str].get("domain", ""),
                    "layers": atoms[aid_str].get("layers", []),
                })

        mapping[filepath] = {
            "doc_id": doc_id,
            "category": category,
            "dominant_nature": doc.get("dominant_nature", ""),
            "dominant_provenance": doc.get("dominant_provenance", ""),
            "atoms": [str(a) for a in atom_ids],
            "atom_count": len(atom_ids),
        }
    return mapping

def detect_orphans(file_mapping, laws):
    """Find files at HEAD that aren't in the atom-registry document mapping."""
    import subprocess
    res = subprocess.run(
        ["git", "-C", str(root), "ls-tree", "-r", "--name-only", "HEAD"],
        capture_output=True, text=True, check=True,
    )
    all_files = set()
    for line in res.stdout.strip().splitlines():
        path = line.strip()
        if not path:
            continue
        first = path.split("/")[0]
        if first.startswith("."):
            continue
        all_files.add(path)

    # Files accounted for by atom-registry documents
    mapped_files = set(file_mapping.keys())

    # Files accounted for by laws sources
    law_files = {l["source"] for l in laws if l.get("source")}

    # Known infrastructure files (not orphans)
    infrastructure = {
        "manifest.toml", "sys.toml", "atom-registry.yaml", "LAWS.toml", "LAWS.md",
        "README.md", "pieces.zsh", "S54-HANDOFF.md", "ontological-cartography.md",
        "ontological-cartography.html",
    }
    infra_prefixes = ("bin/", "registry/", "scales/", "coverage/", "_build/", "_projected/", "_data/")

    orphans = []
    for f in sorted(all_files):
        if f in mapped_files or f in law_files or f in infrastructure:
            continue
        if any(f.startswith(p) for p in infra_prefixes):
            continue
        # Archive files are expected in archive/
        if f.startswith("archive/"):
            continue
        orphans.append(f)

    return orphans

def build_ideal_containers(sys_cfg, laws):
    """Define the ideal container layout derived from system configuration."""
    categories = sys_cfg.get("categories", {})
    layers = sys_cfg.get("layers", {}).get("names", [])

    containers = [
        {"name": "axioms", "role": "Laws and axioms — proven formal foundations",
         "layer_range": [0, 3], "expected_categories": ["F", "P", "M", "O", "G"]},
        {"name": "derivations", "role": "Formal models derived from axiom base",
         "layer_range": [2, 6], "expected_categories": ["P", "M", "O", "G", "V"]},
        {"name": "archive", "role": "Historical process record, sessions, fragments, protocols",
         "layer_range": None, "expected_categories": None},
        {"name": "registry", "role": "Entity and event data store (JSON schemas + data)",
         "layer_range": None, "expected_categories": None},
        {"name": "bin", "role": "CLI tooling for system operations",
         "layer_range": None, "expected_categories": None},
        {"name": "scales", "role": "Recursive decomposition at σ-1 and σ+1",
         "layer_range": [0, 6], "expected_categories": None},
        {"name": "coverage", "role": "Integration analysis and priority maps",
         "layer_range": None, "expected_categories": None},
        {"name": "_build/projected", "role": "Dynamic filesystem projections (generated)",
         "layer_range": None, "expected_categories": None},
    ]
    return containers

def main():
    sys_cfg = load_toml("sys.toml")
    manifest = load_toml("manifest.toml")
    registry = load_yaml("atom-registry.yaml")

    documents = registry.get("documents", {})
    atoms = registry.get("atoms", {})
    laws = load_laws(sys_cfg)

    # Extract manifest pieces
    pieces = []
    for key, val in manifest.get("pieces", {}).items():
        pieces.append({
            "id": key,
            "layer": val.get("layer"),
            "kind": val.get("kind", ""),
            "composition_type": val.get("composition", {}).get("type", "atomic"),
            "manifest": val.get("composition", {}).get("manifest"),
        })

    layers = sys_cfg.get("layers", {}).get("names", [])
    categories = sys_cfg.get("categories", {})
    file_mapping = build_file_mapping(documents, atoms)
    orphans = detect_orphans(file_mapping, laws)
    ideal_containers = build_ideal_containers(sys_cfg, laws)

    result = {
        "layers": layers,
        "categories": categories,
        "pieces": pieces,
        "laws": laws,
        "file_to_piece_mapping": file_mapping,
        "ideal_containers": ideal_containers,
        "orphans": orphans,
        "meta": {
            "total_pieces": len(pieces),
            "total_atoms": registry.get("meta", {}).get("total_atoms", 0),
            "total_documents": len(documents),
            "total_orphans": len(orphans),
        },
    }
    json.dump(result, sys.stdout, indent=2)

if __name__ == "__main__":
    main()
