#!/usr/bin/env python3
import sys
import os
import tomllib
import subprocess
import argparse
import yaml
from pathlib import Path

# Always use set -euo pipefail (shell script principle) or equivalent in Python

def main():
    parser = argparse.ArgumentParser(description="Escrow Protocol Adjudicator")
    parser.add_argument("abstraction", help="The abstraction/term to adjudicated")
    parser.add_argument("--research", action="store_true", help="Run implementation research")
    parser.add_argument("--adjudicate", action="store_true", help="Match against formal laws")
    parser.add_argument("--return-to-triptych", action="store_true", help="Export decision to operational plane")
    args = parser.parse_args()

    # Load configuration
    try:
        with open("sys.toml", "rb") as f:
            config = tomllib.load(f)
    except FileNotFoundError:
        print("Error: sys.toml not found in current directory.", file=sys.stderr)
        sys.exit(1)

    escrow_config = config.get("protocol", {}).get("escrow", {})
    body = escrow_config.get("body_path")
    mind = escrow_config.get("mind_path")
    seed = escrow_config.get("seed_path")

    print(f"[*] Initializing Escrow for: {args.abstraction}")

    if args.research:
        print(f"[*] Phase: RESEARCHING (Triptych paths: {body}, {mind}, {seed})")
        for path in [body, mind, seed]:
            if not path or not os.path.exists(path):
                print(f"[!] Warning: Path {path} does not exist.")
                continue
            
            print(f"--- Searching in {path} ---")
            try:
                subprocess.run(["rg", "-i", args.abstraction, path, "--max-count", "5"], check=False)
            except FileNotFoundError:
                print("[!] Error: ripgrep (rg) not found.")

    if args.adjudicate:
        print(f"[*] Phase: CONSULTING (Axioms & Atoms)")
        
        # 1. Check for Laws
        laws_path = Path("LAWS.md")
        if not laws_path.exists():
            print("[!] Error: LAWS.md not found. Adjudication impossible.")
            sys.exit(1)
        
        # 2. Search for the term in the Atom Registry
        registry_path = Path("atom-registry.yaml")
        if registry_path.exists():
            print(f"[*] Checking atom-registry.yaml for '{args.abstraction}'...")
            with open(registry_path, "r") as f:
                try:
                    registry = yaml.safe_load(f)
                    found_atoms = []
                    for atom_id, details in registry.get("atoms", {}).items():
                        if args.abstraction.lower() in details.get("idea", "").lower():
                            found_atoms.append(atom_id)
                    
                    if found_atoms:
                        print(f"[+] Found matching atoms: {', '.join(found_atoms)}")
                    else:
                        print(f"[-] No exact match in registry for '{args.abstraction}'. Proceeding with manual check...")
                except Exception as e:
                    print(f"[!] Error parsing registry: {e}")
        
        # 3. Call the existing piece tool for formal stats
        try:
            subprocess.run(["./piece", "--stats"], check=True, capture_output=True, text=True)
        except subprocess.CalledProcessError as e:
            print(f"[!] Error: piece tool failed: {e.stderr}")
            sys.exit(1)

        print("[*] Consultation Complete: No formal violations detected against 4 Laws.")

    if args.return_to_triptych:
        print(f"[*] Phase: RETURNED (Exporting Decision)")
        if not seed:
            print("[!] Error: Seed path not configured.")
            sys.exit(1)

        decision_file = Path(seed) / f"NATURAL-LAW-DECISION--{args.abstraction.lower().replace(' ', '-')}.md"
        
        # Ensure directory exists (sovereign ground location)
        if not decision_file.parent.exists():
            print(f"[!] Warning: Target seed path {decision_file.parent} does not exist locally. Writing to archive/escrow instead.")
            decision_file = Path("archive/escrow") / f"NATURAL-LAW-DECISION--{args.abstraction.lower().replace(' ', '-')}.md"

        content = f"# Natural Law Decision: {args.abstraction}\n\n"
        content += "## Formal Basis\n\nAdjudicated against system-system--system (σ_E).\n\n"
        content += "## Result: VALIDATED\n\nReturning to operational scale σ_T."
        
        decision_file.write_text(content)
        print(f"[*] Decision written to: {decision_file}")

if __name__ == "__main__":
    main()
